# ResearchOS Frontend Configuration
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ────────────────────────────────────────────────────────────────────────────
# API ENDPOINTS
# ────────────────────────────────────────────────────────────────────────────

# FieldScore API base URL
# Development: http://localhost:5000/api
# Production: /api (reverse proxied through same domain)
REACT_APP_FIELDSCORE_API_URL=/api

# InsightScore is no longer called directly from the browser (that required
# shipping an auth-free API, or a server-to-server secret, into public JS —
# both unacceptable). insightScoreApi in src/services/api.ts now goes through
# FieldScore's authenticated proxy at REACT_APP_FIELDSCORE_API_URL + /insights/*,
# which forwards to InsightScore server-to-server. No separate URL needed here.

# ────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ────────────────────────────────────────────────────────────────────────────

# Environment (development, staging, production)
REACT_APP_ENVIRONMENT=development

# Feature flags
REACT_APP_ENABLE_INSIGHTS=true
REACT_APP_ENABLE_ADA=true
REACT_APP_ENABLE_KOBO_IMPORT=true

# ────────────────────────────────────────────────────────────────────────────
# ADA VOICE (optional — falls back to Web Speech)
# ────────────────────────────────────────────────────────────────────────────
# Any client-side (REACT_APP_*) key is compiled into the public JS bundle and
# readable by anyone via devtools — do not add a REACT_APP_OPENAI_KEY back.
# If OpenAI TTS is wanted again, proxy it through the backend instead.

# ElevenLabs API key — enables Nigerian English voice for Ada
REACT_APP_ELEVENLABS_KEY=
# Voice ID from elevenlabs.io/voice-library (default: Chinwe, Nigerian English female)
REACT_APP_ELEVENLABS_VOICE_ID=jBpfuIE2acCO8z3wKNLl

# ────────────────────────────────────────────────────────────────────────────
# NOTES
# ────────────────────────────────────────────────────────────────────────────
#
# DO NOT add to this file:
#   - API keys or tokens (should be server-side only)
#   - Hardcoded server URLs (use relative URLs or CORS proxy)
#   - Personal email addresses
#   - Database credentials
#   - Admin passwords
#   - Firebase keys (only use from authentication context)
#   - AWS secrets
#   - Any PII
#
# These values will be visible in the built bundle and browser.
# Only add values that are safe to expose to the client.
#
# For sensitive configuration, create backend API endpoints that return
# non-sensitive config values (like contact emails from /api/config/public).
